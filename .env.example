# WordPress Configuration
WP_URL=https://seu-site.com
WP_USERNAME=seu_usuario
WP_APP_PASSWORD=sua_senha_de_aplicativo

# Database
DB_PATH=./data/scentsearch.db

# Scheduler
SCRAPE_HOUR=6
SCRAPE_MINUTE=0

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/scentsearch.log

# Scraping Settings
REQUEST_DELAY=2
MAX_RETRIES=3
REQUEST_TIMEOUT=30
